MORPH_HOME=../hoodi
MORPH_FLAG=morph-hoodi
JWT_SECRET_FILE=${MORPH_HOME}/jwt-secret.txt
GETH_ENTRYPOINT_FILE=./entrypoint-geth.sh
## todo snapshot
HOODI_SNAPSHOT_NAME=mpt-snapshot-20260402-1

## Environment variables for validator node
L1_CHAIN_ID=560048
# Public Hoodi L1 fallback (override locally with: export L1_ETH_RPC=...).
# A follower full node doesn't derive from L1, but ethclient.Dial still needs
# a parseable URL at startup, so keep a valid one here.
L1_ETH_RPC=${L1_ETH_RPC:-https://ethereum-hoodi-rpc.publicnode.com}
L1_BEACON_CHAIN_RPC=${L1_BEACON_CHAIN_RPC:-https://ethereum-hoodi-beacon-api.publicnode.com}
L1MESSAGEQUEUE_CONTRACT=0xd7f39d837f4790b215ba67e0ab63665912648dbe
ROLLUP_CONTRACT=0x57e0e6dde89dc52c01fe785774271504b1e04664
# From-genesis replay: base height 0 = L2 genesis (a follower node ignores the
# derivation heights below; kept for validator use).
DERIVATION_START_HEIGHT=2534958
L1_MSG_START_HEIGHT=2528506
L2_BASE_HEIGHT=0
